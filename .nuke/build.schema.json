{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "definitions": {
    "Host": {
      "type": "string",
      "enum": [
        "AppVeyor",
        "AzurePipelines",
        "Bamboo",
        "Bitbucket",
        "Bitrise",
        "GitHubActions",
        "GitLab",
        "Jenkins",
        "Rider",
        "SpaceAutomation",
        "TeamCity",
        "Terminal",
        "TravisCI",
        "VisualStudio",
        "VSCode"
      ]
    },
    "ExecutableTarget": {
      "type": "string",
      "enum": [
        "BuildRufus",
        "BuildSdCard",
        "Clean",
        "Compile",
        "CreateImageFromRufusConfig",
        "CreatePiImage",
        "FullBuild",
        "IntegrationTest",
        "LaunchRufus",
        "PackClientMsi",
        "PackRepl",
        "PublishAgent",
        "PublishPi",
        "PublishSelfContained",
        "PublishService",
        "PublishToolToNuGet",
        "Restore",
        "ShowVersion",
        "StagePiInstallMedia",
        "Test",
        "TestPowerShell",
        "ValidateTraceability"
      ]
    },
    "Verbosity": {
      "type": "string",
      "description": "",
      "enum": [
        "Verbose",
        "Normal",
        "Minimal",
        "Quiet"
      ]
    },
    "NukeBuild": {
      "properties": {
        "Continue": {
          "type": "boolean",
          "description": "Indicates to continue a previously failed build attempt"
        },
        "Help": {
          "type": "boolean",
          "description": "Shows the help text for this build assembly"
        },
        "Host": {
          "description": "Host for execution. Default is 'automatic'",
          "$ref": "#/definitions/Host"
        },
        "NoLogo": {
          "type": "boolean",
          "description": "Disables displaying the NUKE logo"
        },
        "Partition": {
          "type": "string",
          "description": "Partition to use on CI"
        },
        "Plan": {
          "type": "boolean",
          "description": "Shows the execution plan (HTML)"
        },
        "Profile": {
          "type": "array",
          "description": "Defines the profiles to load",
          "items": {
            "type": "string"
          }
        },
        "Root": {
          "type": "string",
          "description": "Root directory during build execution"
        },
        "Skip": {
          "type": "array",
          "description": "List of targets to be skipped. Empty list skips all dependencies",
          "items": {
            "$ref": "#/definitions/ExecutableTarget"
          }
        },
        "Target": {
          "type": "array",
          "description": "List of targets to be invoked. Default is '{default_target}'",
          "items": {
            "$ref": "#/definitions/ExecutableTarget"
          }
        },
        "Verbosity": {
          "description": "Logging verbosity during build execution. Default is 'Normal'",
          "$ref": "#/definitions/Verbosity"
        }
      }
    }
  },
  "allOf": [
    {
      "properties": {
        "AutoWrite": {
          "type": "boolean",
          "description": "Unattended Rufus write + eject + exit after staging the Pi image"
        },
        "Configuration": {
          "type": "string",
          "description": "Configuration to build"
        },
        "ForcePiImage": {
          "type": "boolean",
          "description": "Force re-stage of the Pi OS image for CreatePiImage"
        },
        "NuGetApiKey": {
          "type": "string",
          "description": "NuGet API key. Defaults to NUGET_API_KEY from the environment"
        },
        "RufusDevice": {
          "type": "string",
          "description": "PhysicalDrive number for Rufus --device (unattended SD write)"
        },
        "RufusPlatform": {
          "type": "string",
          "description": "Rufus MSBuild platform (x64|Win32)"
        },
        "RufusProfile": {
          "type": "string",
          "description": "Saved Rufus MouseKeyProxy Pi HID profile name"
        },
        "RufusRoot": {
          "type": "string",
          "description": "Path to the rufus-mkp repository (MouseKeyProxy Rufus fork)"
        }
      }
    },
    {
      "$ref": "#/definitions/NukeBuild"
    }
  ]
}
